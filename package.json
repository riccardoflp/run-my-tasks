{
  "name": "run-my-tasks",
  "displayName": "Run My Tasks",
  "description": "Quickly run workspace tasks from a status bar picker or side panel",
  "version": "0.2.0",
  "license": "MIT",
  "publisher": "RiccardoFilippozzi",
  "repository": "https://github.com/riccardoflp/run-my-tasks",
  "engines": {
    "vscode": "^1.90.0"
  },
  "icon": "resources/icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "tasks",
    "task runner",
    "build",
    "status bar"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "run-my-tasks-container",
          "title": "Run My Tasks",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "run-my-tasks-container": [
        {
          "id": "run-my-tasks.groupsView",
          "name": "Groups"
        },
        {
          "id": "run-my-tasks.tasksView",
          "name": "Tasks"
        }
      ]
    },
    "commands": [
      {
        "command": "run-my-tasks.showTaskPicker",
        "title": "Run Task...",
        "category": "Run My Tasks"
      },
      {
        "command": "run-my-tasks.refreshTasksView",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Run My Tasks"
      },
      {
        "command": "run-my-tasks.runTaskFromTree",
        "title": "Run Task",
        "icon": "$(run)",
        "category": "Run My Tasks"
      },
      {
        "command": "run-my-tasks.stopTaskFromTree",
        "title": "Stop Task",
        "icon": "$(stop)",
        "category": "Run My Tasks"
      },
      {
        "command": "run-my-tasks.createGroup",
        "title": "Create Group",
        "icon": "$(add)",
        "category": "Run My Tasks"
      },
      {
        "command": "run-my-tasks.renameGroup",
        "title": "Rename Group",
        "icon": "$(edit)",
        "category": "Run My Tasks"
      },
      {
        "command": "run-my-tasks.deleteGroup",
        "title": "Delete Group",
        "icon": "$(trash)",
        "category": "Run My Tasks"
      },
      {
        "command": "run-my-tasks.addTaskToGroup",
        "title": "Add to Group",
        "category": "Run My Tasks"
      },
      {
        "command": "run-my-tasks.removeTaskFromGroup",
        "title": "Remove from Group",
        "category": "Run My Tasks"
      },
      {
        "command": "run-my-tasks.runGroup",
        "title": "Run Group",
        "icon": "$(run-all)",
        "category": "Run My Tasks"
      },
      {
        "command": "run-my-tasks.stopGroup",
        "title": "Stop Group",
        "icon": "$(debug-stop)",
        "category": "Run My Tasks"
      },
      {
        "command": "run-my-tasks.openTasksJson",
        "title": "Open tasks.json",
        "icon": "$(go-to-file)",
        "category": "Run My Tasks"
      }
    ],
    "keybindings": [
      {
        "command": "run-my-tasks.showTaskPicker",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "run-my-tasks.renameGroup",
        "key": "f2",
        "when": "focusedView == run-my-tasks.groupsView && viewItem == virtualGroup"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "run-my-tasks.createGroup",
          "when": "view == run-my-tasks.groupsView",
          "group": "navigation"
        },
        {
          "command": "run-my-tasks.refreshTasksView",
          "when": "view == run-my-tasks.groupsView || view == run-my-tasks.tasksView",
          "group": "navigation"
        },
        {
          "command": "run-my-tasks.openTasksJson",
          "when": "view == run-my-tasks.groupsView || view == run-my-tasks.tasksView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "run-my-tasks.runTaskFromTree",
          "when": "view == run-my-tasks.tasksView && viewItem == idleTask",
          "group": "inline"
        },
        {
          "command": "run-my-tasks.stopTaskFromTree",
          "when": "view == run-my-tasks.tasksView && viewItem == runningTask",
          "group": "inline"
        },
        {
          "command": "run-my-tasks.runTaskFromTree",
          "when": "view == run-my-tasks.groupsView && viewItem == idleTaskInGroup",
          "group": "inline"
        },
        {
          "command": "run-my-tasks.stopTaskFromTree",
          "when": "view == run-my-tasks.groupsView && viewItem == runningTaskInGroup",
          "group": "inline"
        },
        {
          "command": "run-my-tasks.runGroup",
          "when": "view == run-my-tasks.groupsView && viewItem == virtualGroup",
          "group": "inline@1"
        },
        {
          "command": "run-my-tasks.stopGroup",
          "when": "view == run-my-tasks.groupsView && viewItem == virtualGroup",
          "group": "inline@2"
        },
        {
          "command": "run-my-tasks.deleteGroup",
          "when": "view == run-my-tasks.groupsView && viewItem == virtualGroup",
          "group": "inline@3"
        },
        {
          "command": "run-my-tasks.renameGroup",
          "when": "view == run-my-tasks.groupsView && viewItem == virtualGroup",
          "group": "1_modification@1"
        },
        {
          "command": "run-my-tasks.addTaskToGroup",
          "when": "view == run-my-tasks.tasksView && (viewItem == idleTask || viewItem == runningTask)",
          "group": "1_group"
        },
        {
          "command": "run-my-tasks.removeTaskFromGroup",
          "when": "view == run-my-tasks.groupsView && (viewItem == idleTaskInGroup || viewItem == runningTaskInGroup)",
          "group": "1_group"
        }
      ]
    },
    "configuration": {
      "title": "Run My Tasks",
      "properties": {
        "runMyTasks.statusBarAlignment": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "left",
          "description": "Which side of the status bar to place the task runner button."
        },
        "runMyTasks.statusBarPriority": {
          "type": "number",
          "default": 100,
          "description": "Priority of the status bar item. Higher numbers appear further left (for Left alignment)."
        },
        "runMyTasks.showTaskType": {
          "type": "boolean",
          "default": true,
          "description": "Show the task source and command as detail lines in the picker."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^3.0.0"
  }
}
